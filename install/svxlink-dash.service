[Unit]
Description={{ version_info.dashboard_name }} Web Configuration Dashboard
After=network.target svxlink.service
Wants=network.target

[Service]
Type=simple
User=svxlink
Group=svxlink
WorkingDirectory=/opt/dashboard
ExecStart=/usr/bin/python3 /opt/dashboard/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target