{
  "profile_id": "dual_usb",
  "name": "Dual USB Sound Fob Interfaces",
  "type": "multi_interface",
  "family": "usb_multi_interface",
  "ports": 2,
  "audio": {
    "backend": "alsa_multi_device",
    "devices": "discovered",
    "rate": 48000,
    "format": "S16_LE"
  },
  "control": {
  "backend": "per_port_selected",
  "devices": "discovered",
  "supported_methods": [
    "hidraw",
    "gpiod",
    "serial"
  ]
  },
  "preparation": {
  "required": true,
  "requires_reboot": false,
  "service": "dual_usb_prepare",
  "resume_after_reboot": "environment_page"
  },
  "port_map": {
  "1": {
    "rx_audio": "plughw:0",
    "tx_audio": "plughw:0",
    "ptt": null,
    "cos": null,
    "enable": null,
    "control": "per_port_selected"
  },
  "2": {
    "rx_audio": "plughw:1",
    "tx_audio": "plughw:1",
    "ptt": null,
    "cos": null,
    "enable": null,
    "control": "per_port_selected"
  }
},
  "notes": [
    "Use this for two separate USB sound fobs or USB radio interfaces.",
    "Each radio port is expected to have its own USB audio device.",
    "PTT and COS control may be HIDRAW, GPIOD, serial, or another supported method selected later per port.",
    "Device identity should be discovered and pinned later by stable ALSA/control paths rather than raw enumeration order."
  ]
  }