{
  "profile_id": "ics_4x",
  "name": "ICS-CTRLS 4X Board",
  "manufacturer": "ICS-CTRLS",
  "type": "port_based",
  "family": "ics",
  "ports": 4,
  "audio": {
    "backend": "alsa_multichannel",
    "rate": 48000,
    "format": "S32_LE",
    "hardware_channels": 10
  },
  "gpio": {
    "backend": "mcp23017_dual",
    "i2c_required": true,
    "overlay_required": true
  },
  "port_map": {
    "1": {
      "rx_audio": "alsa:rx1",
      "tx_audio": "alsa:tx1",
      "ptt": "TX_1",
      "cos": "RX_1",
      "enable": "EN_1",
      "control": "CT_1"
    },
    "2": {
      "rx_audio": "alsa:rx2",
      "tx_audio": "alsa:tx2",
      "ptt": "TX_2",
      "cos": "RX_2",
      "enable": "EN_2",
      "control": "CT_2"
    },
    "3": {
      "rx_audio": "alsa:rx3",
      "tx_audio": "alsa:tx3",
      "ptt": "TX_3",
      "cos": "RX_3",
      "enable": "EN_3",
      "control": "CT_3"
    },
    "4": {
      "rx_audio": "alsa:rx4",
      "tx_audio": "alsa:tx4",
      "ptt": "TX_4",
      "cos": "RX_4",
      "enable": "EN_4",
      "control": "CT_4"
    }
  },
  "rules": {
    "controller_ownership_required": true,
    "max_ports": 4,
    "max_active_repeater_controllers": 1
  },
    "preparation": {
    "required": true,
    "requires_reboot": true,
    "service": "ics_prepare",
    "resume_after_reboot": "/ics_prepare"
  },
  
  "notes": [
    "This board is represented as four logical ports.",
    "Ports, not radios, are the primary configuration object.",
    "SvxLink should use named ALSA endpoints rather than raw channel numbers."
  ]
}