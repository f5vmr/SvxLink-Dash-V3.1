/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2711", "brcm,bcm2835";

    /* Fixed clock for SC16IS752 */
    fragment@0 {
        target-path = "/";

        __overlay__ {
            sc16_clk: sc16_clk {
                compatible = "fixed-clock";
                #clock-cells = <0>;
                clock-frequency = <3686400>;
            };
        };
    };

    /* I2C devices */
    fragment@1 {
        target = <&i2c1>;

        __overlay__ {
            status = "okay";

            #address-cells = <1>;
            #size-cells = <0>;

            /* MCP23017 @ 0x26 — expansion */
            mcp26: gpio@26 {
                compatible = "microchip,mcp23017";
                reg = <0x26>;
                gpio-controller;
                #gpio-cells = <2>;
                #address-cells = <0>;

                interrupt-parent = <&gpio>;
                interrupts = <25 8>;

                interrupt-controller;
                #interrupt-cells = <2>;
                microchip,irq-mirror;

                gpio-line-names =
                    "EXP_1",  "EXP_2",  "EXP_3",  "EXP_4",
                    "EXP_5",  "EXP_6",  "EXP_7",  "EXP_8",
                    "REL_1",  "REL_2",  "EXP_10", "PCM_PDWN",
                    "EXP_12", "EXP_13", "EXP_14", "EXP_15";
            };

            /* MCP23017 @ 0x27 — core RX/TX ports 1-4 */
            mcp27: gpio@27 {
                compatible = "microchip,mcp23017";
                reg = <0x27>;
                gpio-controller;
                #gpio-cells = <2>;
                #address-cells = <0>;

                interrupt-parent = <&gpio>;
                interrupts = <23 8>;

                interrupt-controller;
                #interrupt-cells = <2>;
                microchip,irq-mirror;

                gpio-line-names =
                    "EN_1", "EN_2", "TX_1", "TX_2",
                    "CT_1", "CT_2", "RX_1", "RX_2",
                    "EN_3", "EN_4", "TX_3", "TX_4",
                    "CT_3", "CT_4", "RX_3", "RX_4";

            };
                        /* ADS1015 ADC @ 0x48 */
            ads1015_48: adc@48 {
                compatible = "ti,ads1015";
                reg = <0x48>;
                #address-cells = <1>;
                #size-cells = <0>;

                channel@0 {
                    reg = <0>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@1 {
                    reg = <1>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@2 {
                    reg = <2>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@3 {
                    reg = <3>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };
            };

            /* ADS1015 ADC @ 0x49 */
            ads1015_49: adc@49 {
                compatible = "ti,ads1015";
                reg = <0x49>;
                #address-cells = <1>;
                #size-cells = <0>;

                channel@0 {
                    reg = <0>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@1 {
                    reg = <1>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@2 {
                    reg = <2>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };

                channel@3 {
                    reg = <3>;
                    ti,gain = <2>;
                    ti,datarate = <4>;
                };
            };
            /* SC16IS752 UART / GPS */
            sc16: serial@4d {
                compatible = "nxp,sc16is752";
                reg = <0x4d>;

                clocks = <&sc16_clk>;

                interrupt-parent = <&gpio>;
                interrupts = <24 2>;
            };
        };
    };
};